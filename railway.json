{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node apps/api/dist/main",
    "watchPatterns": ["apps/api/**", "apps/web/**", "package.json", "pnpm-lock.yaml", "pnpm-workspace.yaml", "Dockerfile"]
  }
}
